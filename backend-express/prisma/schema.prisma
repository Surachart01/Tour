  discount_amount      Decimal            @db.Decimal(10, 2)
  discount_type        String             @db.VarChar(10)
  valid_for_extra_beds Boolean?           @default(false)
  combinable           Boolean?           @default(true)
  free_meals_abf       Int?               @default(0)
  free_meals_lunch     Int?               @default(0)
  free_meals_dinner    Int?               @default(0)
  created_at           DateTime?          @default(now()) @db.Timestamp(6)
  updated_at           DateTime?          @default(now()) @db.Timestamp(6)
  hotels               hotels?            @relation(fields: [hotel_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  hotel_trip_items     hotel_trip_items[]

  @@unique([hotel_id, discount_amount, discount_type])
}

model hotel_room_type_items {
  id                 Int               @id @default(autoincrement())
  hotel_trip_item_id Int?
  room_type_id       Int?
  room_type          String?           @db.VarChar(100)
  adults             Int?              @default(0)
  children           Int?              @default(0)
  complimentary_abf  Boolean?          @default(false)
  extra_adult_bed    Boolean?          @default(false)
  extra_child_bed    Boolean?          @default(false)
  sharing_bed        Boolean?          @default(false)
  created_at         DateTime?         @default(now()) @db.Timestamp(6)
  updated_at         DateTime?         @default(now()) @db.Timestamp(6)
  hotel_trip_items   hotel_trip_items? @relation(fields: [hotel_trip_item_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model hotel_trip_items {
