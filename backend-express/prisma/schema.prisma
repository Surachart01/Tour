model hotels {
  id               Int                @id @default(autoincrement())
  uuid             String             @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  name             String             @unique @db.VarChar(255)
  city             String             @db.VarChar(100)
  notes            String?
  address          String?            @db.VarChar(255)
  created_at       DateTime?          @default(now()) @db.Timestamp(6)
  updated_at       DateTime?          @default(now()) @db.Timestamp(6)
  deleted_at       DateTime?          @db.Timestamp(6)
  user_id          Int?
  country          String?            @default("Thailand") @db.VarChar(100)
  display_order    Int?               @default(0) @map("display_order")
  hotel_contacts   hotel_contacts[]
  hotel_fees       hotel_fees[]
  hotel_promotions hotel_promotions[]
  hotel_trip_items hotel_trip_items[]
  room_types       room_types[]
  stop_sales       stop_sales[]
  tour_trip_item_hotels tour_trip_item_hotels[]
}

model invoice_items {
  id          Int      @id @default(autoincrement())
  invoice_id  Int
  name        String   @db.VarChar(255)
  time        String?  @db.VarChar(255)
  description String?
  location    String?  @db.VarChar(255)
  cost        Decimal  @db.Decimal(10, 2)
  discount    Decimal? @default(0) @db.Decimal(10, 2)
  price       Decimal  @db.Decimal(10, 2)
  tax         Decimal? @default(0) @db.Decimal(10, 2)
  created_at  DateTime @default(now()) @db.Timestamptz(6)
  invoices    invoices @relation(fields: [invoice_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model invoices {
  id            Int             @id @default(autoincrement())
  trip_id       Int             @unique
  total_cost    Decimal         @db.Decimal(10, 2)
  created_at    DateTime        @default(now()) @db.Timestamptz(6)
  invoice_items invoice_items[]
  trips         trips           @relation(fields: [trip_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
