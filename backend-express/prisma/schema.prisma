  trip_item_id          Int?
  hotel_id              Int?
  promotions            Int?
  from_date             DateTime                @db.Timestamp(6)
  to_date               DateTime                @db.Timestamp(6)
  city                  String                  @db.VarChar(100)
  tour_package          String?                 @db.VarChar(255)
  hotel_name            String                  @db.VarChar(255)
  nights                Int
  single_price          Decimal?                @db.Decimal(10, 2)
  double_price          Decimal?                @db.Decimal(10, 2)
  extra_bed_price       Decimal?                @db.Decimal(10, 2)
  room_type             String?                 @db.VarChar(100)
  abf_price             Decimal?                @db.Decimal(10, 2)
  lunch_price           Decimal?                @db.Decimal(10, 2)
  dinner_price          Decimal?                @db.Decimal(10, 2)
  rsvn_in               DateTime?               @db.Timestamp(6)
  rsvn_out              DateTime?               @db.Timestamp(6)
  payment_date          DateTime?               @db.Timestamp(6)
  approved              Boolean?                @default(false)
